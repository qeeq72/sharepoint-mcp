# SharePoint MCP Server Configuration

# Debug mode (True/False)
DEBUG=False

# SharePoint connection information
TENANT_ID=your_tenant_id
CLIENT_ID=your_client_id
CLIENT_SECRET=your_client_secret
SITE_URL=https://your-tenant.sharepoint.com/sites/your-site

# Optional: default search scope for the search_sharepoint tool when no sites
# are passed in the call. Comma-separated site URLs or site IDs.
# If empty, search covers all sites in the tenant (capped by max_sites).
# SEARCH_SITES=https://your-tenant.sharepoint.com/sites/site1,https://your-tenant.sharepoint.com/sites/site2

# Optional: tenant search region for the Microsoft Search API (/search/query),
# required with app-only tokens (e.g. NAM, EMEA). Auto-detected if empty.
# SEARCH_REGION=EMEA

# Optional: Certificate-based authentication
# Uncomment and configure these if using certificate authentication
# CERT_THUMBPRINT=your_certificate_thumbprint
# CERT_PRIVATE_KEY_PATH=./key.pem
# CERT_PUBLIC_CERT_PATH=./certificate.pem

# HTTP transport settings (for web/Docker deployment)
MCP_TRANSPORT=stdio        # stdio | sse | streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8000

# Static bearer token protecting the HTTP transports (sse/streamable-http).
# Clients must send "Authorization: Bearer <token>" on every request.
# REQUIRED whenever the port is reachable from anywhere but localhost.
# Generate one with: openssl rand -hex 32
# MCP_AUTH_TOKEN=

# Provisioning tools (create_sharepoint_site, create_intelligent_list,
# create_advanced_document_library, create_modern_page, create_news_post)
# are disabled by default — they create objects tenant-wide. Opt in:
# MCP_ENABLE_PROVISIONING_TOOLS=True

# Document-parsing tools (get_document_content, get_document_by_path) are
# disabled by default; download_file returns raw base64 instead. Opt in:
# MCP_ENABLE_DOCUMENT_PARSING_TOOLS=True

# Additionally hide individual tools by name (comma-separated), applied
# after the group flags:
# MCP_DISABLED_TOOLS=upload_document,update_list_item

# Site allowlist (comma-separated site URLs or site IDs). When set, tools
# refuse to access sites outside the list, list_sites filters its output,
# and the default search scope becomes this list. Application-level guard
# only — for a hard boundary use the Sites.Selected permission in Entra ID.
# MCP_ALLOWED_SITES=https://your-tenant.sharepoint.com/sites/site1,https://your-tenant.sharepoint.com/sites/site2

# Required application permissions in Microsoft Entra ID:
# - Sites.Read.All (reading site content)
# - Sites.ReadWrite.All (modifying site content) 
# - Sites.Manage.All (creating sites)
# - Files.ReadWrite.All (document operations)
# - User.Read.All (for user profile information)
#
# NOTE: For all write operations (create list items, upload files, create pages)
# you MUST have Sites.ReadWrite.All or Files.ReadWrite.All permission